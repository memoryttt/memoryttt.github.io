---
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<p>© {year} Memory TTT · Built with Astro · Hosted on GitHub Pages</p>
		<div class="links">
			<a href="/rss.xml">RSS</a>
			<a href="/about">关于</a>
			<a href="https://github.com/memoryttt/memoryttt.github.io" target="_blank" rel="noreferrer">仓库</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 2.5rem 1.25rem 4rem;
		color: rgb(var(--gray));
	}

	.inner {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		border-top: 1px solid rgba(var(--gray), 0.16);
		padding-top: 1.5rem;
	}

	p {
		margin: 0;
		font-size: 0.95rem;
	}

	.links {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.links a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
	}

	.links a:hover {
		color: var(--accent);
	}
</style>
