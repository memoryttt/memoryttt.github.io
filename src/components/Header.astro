---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<a href="https://github.com/memoryttt" target="_blank" rel="noreferrer">GitHub</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 1rem 1.25rem;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.76);
		border-bottom: 1px solid rgba(var(--gray), 0.15);
	}

	nav {
		max-width: 1120px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand {
		font-size: 1rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-decoration: none;
		color: rgb(var(--black));
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex-wrap: wrap;
	}

	.links a {
		padding: 0.65rem 0.9rem;
		border-radius: 999px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-size: 0.95rem;
		transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
	}

	.links a:hover {
		background: rgba(var(--gray), 0.1);
		color: rgb(var(--black));
		transform: translateY(-1px);
	}

	@media (max-width: 720px) {
		header {
			padding: 0.8rem 1rem;
		}

		nav {
			align-items: flex-start;
			flex-direction: column;
		}
	}
</style>
