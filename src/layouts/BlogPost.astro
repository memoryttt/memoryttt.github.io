---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}

			.hero-image {
				width: 100%;
				max-width: 1120px;
				margin: 2rem auto 0;
				padding: 0 1rem;
			}

			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 auto;
				border-radius: 24px;
				box-shadow: var(--box-shadow);
			}

			.prose {
				width: 760px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2rem 1rem 3rem;
				color: rgb(var(--gray-dark));
			}

			.title {
				margin-bottom: 2rem;
				text-align: left;
			}

			.title h1 {
				margin: 0.35em 0 0.4em;
				font-size: clamp(2.2rem, 5vw, 4rem);
				line-height: 1.05;
			}

			.description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 1.05rem;
			}

			.date {
				display: flex;
				gap: 0.75rem;
				flex-wrap: wrap;
				align-items: center;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}

			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={1600} height={900} src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="title">
						<div class="date">
							<span><FormattedDate date={pubDate} /></span>
							{updatedDate && (
								<div class="last-updated-on">更新于 <FormattedDate date={updatedDate} /></div>
							)}
						</div>
						<h1>{title}</h1>
						<p class="description">{description}</p>
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
