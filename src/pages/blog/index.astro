---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`文章 · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				max-width: 1120px;
				margin: 0 auto;
				padding: 3rem 1rem 1rem;
			}

			.hero p {
				max-width: 42rem;
				color: rgb(var(--gray-dark));
			}

			.grid {
				max-width: 1120px;
				margin: 0 auto;
				padding: 1rem;
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
			}

			.card {
				text-decoration: none;
				color: inherit;
				border-radius: 28px;
				overflow: hidden;
				border: 1px solid rgba(var(--gray), 0.16);
				background: rgba(255, 255, 255, 0.82);
				box-shadow: 0 16px 40px rgba(var(--gray), 0.12);
				transition: transform 0.22s ease, box-shadow 0.22s ease;
			}

			.card:hover {
				transform: translateY(-4px);
				box-shadow: 0 24px 60px rgba(var(--gray), 0.18);
			}

			.card img {
				display: block;
				width: 100%;
			}

			.content {
				padding: 1.25rem;
			}

			.meta {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin-bottom: 0.7rem;
			}

			.title {
				margin: 0 0 0.55rem;
				font-size: 1.35rem;
			}

			.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 720px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Archive</p>
				<h1>文章</h1>
				<p>这里收录所有已发布内容。偏向长期有效的技术笔记与可复用的折腾记录。</p>
			</section>
			<section class="grid">
				{posts.map((post) => (
					<a class="card" href={`/blog/${post.id}/`}>
						{post.data.heroImage && (
							<Image width={1200} height={675} src={post.data.heroImage} alt={post.data.title} />
						)}
						<div class="content">
							<div class="meta"><FormattedDate date={post.data.pubDate} /></div>
							<h2 class="title">{post.data.title}</h2>
							<p class="desc">{post.data.description}</p>
						</div>
					</a>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>
