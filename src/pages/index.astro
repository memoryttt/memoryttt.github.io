---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				max-width: 1120px;
				margin: 0 auto;
				padding: 4rem 1rem 2rem;
				display: grid;
				grid-template-columns: 1.2fr 0.8fr;
				gap: 2rem;
				align-items: end;
			}

			.eyebrow {
				display: inline-flex;
				padding: 0.35rem 0.75rem;
				border-radius: 999px;
				background: rgba(var(--accent-rgb), 0.1);
				color: var(--accent);
				font-size: 0.82rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			h1 {
				font-size: clamp(3rem, 8vw, 5.8rem);
				line-height: 0.95;
				letter-spacing: -0.04em;
				margin: 1rem 0;
			}

			.lead {
				font-size: 1.15rem;
				max-width: 40rem;
				color: rgb(var(--gray-dark));
			}

			.hero-card {
				padding: 1.4rem;
				border-radius: 28px;
				background: rgba(255, 255, 255, 0.76);
				border: 1px solid rgba(var(--gray), 0.16);
				box-shadow: 0 30px 80px rgba(var(--gray), 0.14);
			}

			.hero-card p {
				margin: 0.4rem 0;
			}

			.actions {
				display: flex;
				gap: 0.9rem;
				margin-top: 1.6rem;
				flex-wrap: wrap;
			}

			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.9rem 1.2rem;
				border-radius: 999px;
				text-decoration: none;
				font-weight: 700;
			}

			.button.primary {
				background: var(--accent);
				color: white;
			}

			.button.ghost {
				background: rgba(var(--gray), 0.08);
				color: rgb(var(--black));
			}

			.section {
				max-width: 1120px;
				margin: 0 auto;
				padding: 1rem;
			}

			.section-head {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				margin: 1.2rem 0 1.4rem;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.5rem;
			}

			.featured,
			.card {
				text-decoration: none;
				color: inherit;
				border-radius: 28px;
				overflow: hidden;
				border: 1px solid rgba(var(--gray), 0.16);
				background: rgba(255, 255, 255, 0.82);
				box-shadow: 0 16px 40px rgba(var(--gray), 0.12);
				transition: transform 0.22s ease, box-shadow 0.22s ease;
			}

			.featured:hover,
			.card:hover {
				transform: translateY(-4px);
				box-shadow: 0 24px 60px rgba(var(--gray), 0.18);
			}

			.cover img {
				display: block;
				width: 100%;
				height: auto;
			}

			.content {
				padding: 1.25rem 1.25rem 1.4rem;
			}

			.meta {
				font-size: 0.92rem;
				color: rgb(var(--gray));
				margin-bottom: 0.7rem;
			}

			.title {
				font-size: 1.35rem;
				line-height: 1.2;
				margin: 0 0 0.55rem;
			}

			.desc {
				margin: 0;
				color: rgb(var(--gray-dark));
			}

			@media (max-width: 900px) {
				.hero {
					grid-template-columns: 1fr;
					padding-top: 2.5rem;
				}
			}

			@media (max-width: 720px) {
				.grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<span class="eyebrow">Personal Blog</span>
					<h1>写技术，记折腾，也存下一点长期有用的东西。</h1>
					<p class="lead">
						这里是 Memory TTT。主要写 AI、自动化、OpenClaw、macOS、黑苹果，以及各种工具流的踩坑与复盘。
					</p>
					<div class="actions">
						<a class="button primary" href="/blog">开始看文章</a>
						<a class="button ghost" href="/about">了解这个站</a>
					</div>
				</div>
				<div class="hero-card">
					<p><strong>风格：</strong> 干净、快速、中文优先</p>
					<p><strong>内容：</strong> 技术笔记 / 配置档案 / 工作流</p>
					<p><strong>部署：</strong> Astro + GitHub Pages</p>
				</div>
			</section>

			{featured && (
				<section class="section">
					<div class="section-head">
						<h2>最新文章</h2>
						<a href="/blog">查看全部 →</a>
					</div>
					<a class="featured" href={`/blog/${featured.id}/`}>
						{featured.data.heroImage && (
							<div class="cover">
								<Image width={1600} height={900} src={featured.data.heroImage} alt={featured.data.title} />
							</div>
						)}
						<div class="content">
							<div class="meta"><FormattedDate date={featured.data.pubDate} /></div>
							<h3 class="title">{featured.data.title}</h3>
							<p class="desc">{featured.data.description}</p>
						</div>
					</a>
				</section>
			)}

			{rest.length > 0 && (
				<section class="section">
					<div class="section-head">
						<h2>更多内容</h2>
					</div>
					<div class="grid">
						{rest.map((post) => (
							<a class="card" href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<div class="cover">
										<Image width={1200} height={675} src={post.data.heroImage} alt={post.data.title} />
									</div>
								)}
								<div class="content">
									<div class="meta"><FormattedDate date={post.data.pubDate} /></div>
									<h3 class="title">{post.data.title}</h3>
									<p class="desc">{post.data.description}</p>
								</div>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>
